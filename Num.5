#include <iostream>
using namespace std;

int main() {
    int numeros[100];
    int num;
    int suma = 0;
    int contador = 0;

    cout << "Ingrese numeros (0 para terminar): ";
    cin >> num;

    while(num != 0){
        numeros[contador] = num;
        suma += num;
        contador++;

        cin >> num;
    }

    if(contador > 0){
        float promedio = (float)suma / contador;

        cout << "Cantidad: " << contador << endl;
        cout << "Suma: " << suma << endl;
        cout << "Promedio: " << promedio << endl;
    } else {
        cout << "No se ingresaron numeros";
    }

    return 0;
}
