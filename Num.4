#include <iostream>
using namespace std;

int main() {
    int datos[8] = {8, 9, 3, 6, 7, 1, 4, 2};
    int num;
    bool encontrado = false;

    cout << "Ingrese numero: ";
    cin >> num;

    for(int i = 0; i < 8; i++){
        if(datos[i] == num){
            cout << "Encontrado en posicion: " << i;
            encontrado = true;
            break;
        }
    }

   if(encontrado == false){
    cout << "El numero no existe";
}

    return 0;
}
