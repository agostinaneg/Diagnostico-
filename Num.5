#include <iostream>
using namespace std;

int main() {
    int num;
    int suma = 0;
    int contador = 0;

    cout << "Ingrese numeros (0 si quiere terminar):" << endl;

    cin >> num;

    while(num == 0){
        cout << "No se ingresaron numeros" << endl;
        return 0;
    }

    while(num == 0){
        suma = suma + num;
        contador = contador + 1;

        cin >> num;
    }

    float promedio = (float)suma / contador;

    cout << "Cantidad: " << contador << endl;
    cout << "Suma: " << suma << endl;
    cout << "Promedio: " << promedio << endl;

    return 0;
}
